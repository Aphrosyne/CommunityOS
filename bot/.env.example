# ==================================
# CommunityOS Bot 配置文件
# 复制此文件为 .env 并修改实际值
# ==================================

# NoneBot2 驱动（FastAPI，后续支持 Web 管理面板）
DRIVER=~fastapi

# 调试模式
DEBUG=false

# OneBot 连接地址（NapCat WebSocket）
ONEBOT_WS_URLS=["ws://127.0.0.1:3001"]

# 管理员 QQ 号（多个用逗号分隔）
SUPERUSERS=[]

# 机器人 QQ 号
BOT_QQ=0

# 日志级别
LOG_LEVEL=INFO

# 数据目录（相对于 bot/ 目录）
DATA_DIR=data

# 备份目录
BACKUP_DIR=../backups

# 被 @ 时的回复内容
GREETING_REPLY=你好呀 这里是柳千语

# 图片投稿目标群号
IMAGE_SUBMIT_GROUP=0

# 图片投稿冷却时间（秒）
IMAGE_COOLDOWN=60

# 在线解混淆网址
IMAGE_DECODE_URL=https://ranzt.com/xiaofanqiehunxiao

# 发布模式超时（秒）
PUBLISH_TIMEOUT=180

# 单次发布图片上限
PUBLISH_MAX_IMAGES=10

# 回复节流窗口（秒）
REPLY_THROTTLE=5

# 发布冷却：cooldown = min(base + per_image * count, max)
PUBLISH_COOLDOWN_BASE=30
PUBLISH_COOLDOWN_PER_IMAGE=10
PUBLISH_COOLDOWN_MAX=90

# 超时扫描间隔（秒）
SESSION_SCAN_INTERVAL=10

# 指令冷却时间（秒）
COMMAND_COOLDOWN=30

# 版本号
BOT_VERSION=0.8.2
