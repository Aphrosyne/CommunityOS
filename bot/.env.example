# ==================================
# CommunityOS Bot 配置文件
# 复制此文件为 .env 并修改实际值
# ==================================

# NoneBot2 驱动（FastAPI，后续支持 Web 管理面板）
DRIVER=~fastapi

# 调试模式
DEBUG=false

# OneBot 连接地址（NapCat WebSocket）
ONEBOT_WS_URLS=["ws://127.0.0.1:3001"]

# 管理员 QQ 号（多个用逗号分隔）
SUPERUSERS=[]

# 机器人 QQ 号
BOT_QQ=0

# 日志级别
LOG_LEVEL=INFO

# 数据目录（相对于 bot/ 目录）
DATA_DIR=data

# 备份目录
BACKUP_DIR=../backups

# 被 @ 时的回复内容
GREETING_REPLY=你好呀 这里是柳千语
